#!/usr/bin/env bash
# Repo-local venv helper for macOS/Linux (zsh/bash)
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
VENV="$ROOT/.venv"
ACTIVATE="$VENV/bin/activate"
PY="$VENV/bin/python3"
PIP="$VENV/bin/pip"

usage() {
  cat <<'USAGE'
Usage:
  source ./env start
  ./env stop
  ./env status
  ./env recreate
  ./env run <cmd...>
  ./env python [args...]
  ./env pip [args...]

Notes:
  - "start" must be SOURCED to activate in the current shell:
      source ./env start
  - "stop" deactivates (if active) and is safe to run any time.
USAGE
}

die() { echo "[ERROR] $*" >&2; exit 2; }
info() { echo "[INFO] $*"; }
ok() { echo "[OK] $*"; }

ensure_venv_dir() {
  if [[ ! -d "$VENV" ]]; then
    die ".venv not found at: $VENV (run: ./env recreate)"
  fi
}

is_active_here() {
  # True if current shell is using this repo's venv
  [[ "${VIRTUAL_ENV-}" == "$VENV" ]]
}

cmd="${1:-}"
shift || true

case "$cmd" in
  start)
    ensure_venv_dir
    if [[ ! -f "$ACTIVATE" ]]; then
      die "activate script not found: $ACTIVATE (run: ./env recreate)"
    fi

    if is_active_here; then
      ok "Already active: $VENV"
      return 0 2>/dev/null || exit 0
    fi

    info "Activating venv: $VENV"
    # Must be sourced
    # shellcheck disable=SC1090
    source "$ACTIVATE"
    ok "Activated: $VIRTUAL_ENV"
    ;;

  stop)
    if [[ -n "${VIRTUAL_ENV-}" ]]; then
      info "Deactivating venv: ${VIRTUAL_ENV}"
      deactivate || true
      ok "Deactivated."
    else
      ok "No venv active."
    fi
    ;;

  status)
    if [[ -n "${VIRTUAL_ENV-}" ]]; then
      echo "[INFO] Active venv: ${VIRTUAL_ENV}"
      if is_active_here; then
        ok "This is the repo venv."
      else
        info "Warning: active venv is NOT this repo's .venv"
      fi
    else
      echo "[INFO] No venv active."
    fi

    if [[ -d "$VENV" ]]; then
      echo "[INFO] Repo venv exists: $VENV"
      if [[ -x "$PY" ]]; then
        echo -n "[INFO] Repo python: "
        "$PY" -V
      else
        echo "[WARN] Repo python missing: $PY"
      fi
    else
      echo "[WARN] Repo venv missing: $VENV"
    fi
    ;;

  recreate)
    # (Re)create venv and install requirements if present
    info "Recreating venv at: $VENV"
    rm -rf "$VENV"
    python3 -m venv "$VENV"
    # shellcheck disable=SC1090
    source "$ACTIVATE"

    info "Upgrading pip/setuptools/wheel"
    python3 -m pip install --upgrade pip setuptools wheel

    if [[ -f "$ROOT/requirements.txt" ]]; then
      info "Installing requirements.txt"
      python3 -m pip install -r "$ROOT/requirements.txt"
      ok "Installed requirements.txt"
    else
      info "No requirements.txt found; skipping dependency install"
    fi

    ok "Venv recreated. Activate with: source ./env start"
    ;;

  run)
    ensure_venv_dir
    if [[ $# -lt 1 ]]; then
      die "Usage: ./env run <cmd...>"
    fi
    "$VENV/bin/env" -i \
      PATH="$VENV/bin:/usr/bin:/bin:/usr/sbin:/sbin" \
      VIRTUAL_ENV="$VENV" \
      "$@"
    ;;

  python)
    ensure_venv_dir
    exec "$PY" "$@"
    ;;

  pip)
    ensure_venv_dir
    exec "$PIP" "$@"
    ;;

  ""|-h|--help|help)
    usage
    ;;

  *)
    die "Unknown command: $cmd (try: ./env help)"
    ;;
esac
